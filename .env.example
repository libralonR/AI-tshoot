# ============================================================
# Grafana MCP
# ============================================================
GRAFANA_URL=<url>
GRAFANA_TOKEN=glsa...
GRAFANA_ORG_ID=1

# ============================================================
# Incidents PostgreSQL MCP (AWS RDS)
# ============================================================
PG_HOST=your-rds-instance.region.rds.amazonaws.com
PG_PORT=5432
PG_DATABASE=incidents
PG_USER=seu-user
PG_PASSWORD=sua-senha
PG_SSLMODE=require

# ============================================================
# VictoriaMetrics MCP
# Pré-requisito: buildar a imagem antes
#   cd k8s/vm-mcp && make build REGISTRY=local VM_MCP_SOURCE=./mcp-victoriametrics-source
# ============================================================
VM_MCP_IMAGE=vm-mcp-server:local
VM_INSTANCE_ENTRYPOINT=http://host.docker.internal:8428
VM_INSTANCE_TYPE=single
VM_INSTANCE_BEARER_TOKEN=

# ============================================================
# OpenAI (Orchestrator LLM)
# ============================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ============================================================
# ServiceNow (KB links nos alertas)
# ============================================================
SERVICENOW_URL=https://your-instance.service-now.com
