# Environment variables for Grafana MCP Server deployment

# Container Registry
REGISTRY=your-registry.example.com
IMAGE_NAME=grafana-mcp-server
VERSION=v1.0.0

# Kubernetes
NAMESPACE=observability

# Grafana Configuration
GRAFANA_URL=http://grafana.observability.svc.cluster.local:3000
GRAFANA_TOKEN=glsa_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GRAFANA_ORG_ID=1
GRAFANA_TIMEOUT_S=15
GRAFANA_INSECURE_SKIP_VERIFY=false
